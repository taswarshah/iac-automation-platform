FROM node:20-alpine

WORKDIR /app

# Copy root files for workspace
COPY package*.json ./
COPY tsconfig.json ./

# Install root dependencies
RUN npm install

# Copy server package
COPY server/package*.json ./server/
COPY server/tsconfig.json ./server/

# Install server dependencies  
WORKDIR /app/server
RUN npm install

# Copy server source
COPY server/src ./src

EXPOSE 3001

CMD ["npm", "run", "dev"]